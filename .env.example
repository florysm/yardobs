# ─── Frontend (browser-visible) ───────────────────────────────────────────────
# Safe to expose — this is not a secret.

# Your Weather Underground PWS station ID (e.g. KWASEATT123).
# Optional: leave blank to start in Preview Mode.
VITE_PWS_STATION_ID=your_station_id_here

# ─── Vercel serverless functions ──────────────────────────────────────────────
# These are server-side only. Never prefix with VITE_ or they'll be bundled
# into the browser and exposed publicly.

# Anthropic API key — used by api/insight.js for AI-generated weather insights
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# There is deliberately no TWC_API_KEY here. api/weather.js only ever uses the
# caller's own key, sent as the x-twc-key header by station owners; Preview Mode
# is served entirely by Open-Meteo, which needs no key. A shared server-side key
# would have meant anonymous preview traffic spending the owner's TWC quota.
