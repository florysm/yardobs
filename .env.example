# ─── Local dev fallback ───────────────────────────────────────────────────────
# When set, the app works without signing in (dev / legacy mode).
# Remove or leave blank in production — users sign in via Supabase instead.
VITE_PWS_STATION_ID=KXXXXX123

# TWC API key — server-side only, never prefix with VITE_
# Used in local dev when VITE_PWS_STATION_ID is set.
TWC_API_KEY=your_twc_api_key_here

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Browser-side (safe to expose — Vite bundles these)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here

# Server-side (Vercel functions — never prefix with VITE_)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here
SUPABASE_SECRET_KEY=your_secret_key_here

# ─── Encryption ───────────────────────────────────────────────────────────────
# 64 hex chars = 32 bytes — used to encrypt stored TWC API keys.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=your_64_hex_chars_here
